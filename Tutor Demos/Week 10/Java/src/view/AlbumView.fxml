<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.image.ImageView?>

<VBox fx:controller="controller.AlbumController" xmlns:fx="http://javafx.com/fxml" alignment="CENTER" spacing="10" stylesheets="/view/style.css">
    <ImageView fx:id="artView" fitWidth="300" preserveRatio="true"/>
    <Text fx:id="albumTxt"/>
    <Text fx:id="artistTxt"/>
    <HBox alignment="CENTER" spacing="10">
        <Label text="Units Sold:"/>
        <Text fx:id="soldTxt"/>
        <Label text="Profit:"/>
        <Text fx:id="profitTxt" />
    </HBox>
    <HBox>
        <Button fx:id="buyBtn" text="Buy" onAction="#handlePurchase" prefWidth="150"/>
        <Button text="Close" onAction="#handleClose" prefWidth="150"/>
    </HBox>

</VBox>