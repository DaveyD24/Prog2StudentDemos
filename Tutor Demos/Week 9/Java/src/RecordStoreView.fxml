<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="RecordStoreController" alignment="CENTER" spacing="10">
    <ImageView fitWidth="250" preserveRatio="true">
        <Image url="image/Serenity.jpg"/>
    </ImageView>
    <Text fx:id="albumTxt"/>
    <Text fx:id="artistTxt"/>
    <HBox alignment="CENTER" spacing="10">

        <!--            Pure FXML Binding Method-->
        <!--            <Label text="Units Sold:"/>-->
        <!--            <Text text="${controller.recordStore.album.sold}" />-->
        <!--            <Label text="Profit:"/>-->
        <!--            <Text text="${controller.recordStore.album.profit}"/>-->

        <!--    Java Method (Recommended)-->
        <Label text="Units Sold:"/>
        <Text fx:id="soldTxt"/>
        <Label text="Profit:"/>
        <Text fx:id="profitTxt" />
    </HBox>
    <Button fx:id="purchaseBtn" text="BUY ($34.99)" prefWidth="250" onAction="#handlePurchase"/>
</VBox>